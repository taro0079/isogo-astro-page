---
import "../styles/global.css";

const pathname = Astro.url.pathname;

const normalizePath = (path: string) => {
  if (path === "/") return "/";
  return path.endsWith("/") ? path.slice(0, -1) : path;
};

const navLinkClass = (href: string) => {
  const current = normalizePath(pathname);
  const target = normalizePath(href);

  return current === target
    ? "px-3 py-2 text-sky-700 font-semibold"
    : "px-3 py-2 text-gray-700 hover:text-sky-700";
};
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>カトリック磯子教会</title>
  </head>
  <body class="space-y-4">
    <nav class="shadow-md py-6 px-4">
      <div class="flex items-center justify-between">
        <div class="shrink-0">
          <a href="/" class="text-xl font-black text-gray-800 hover:text-sky-700">
            カトリック磯子教会
          </a>
        </div>
        <div class="flex items-baseline space-x-4">
          <a class={navLinkClass("/about/")} href="/about/">教会について</a>
          <a class={navLinkClass("/news/")} href="/news/">ニュース</a>
          <a class={navLinkClass("/mass/")} href="/mass/">ミサについて</a>
          <a class={navLinkClass("/course/")} href="/course/">キリスト教講座</a>
          <a class={navLinkClass("/history/")} href="/history/">教会の歴史</a>
        </div>
      </div>
    </nav>
    <div class="px-4 py-4">
      <slot />
    </div>
  </body>
  <div class="mt-20 px-4">
    <div class="text-sm text-gray-400">
      このホームページは、カトリック磯子教会の教会委員会の管理のもとで運営されています。
    </div>
  </div>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>
